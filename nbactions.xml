<?xml version="1.0" encoding="UTF-8"?>
<actions>
    <!-- Acción personalizada para ejecutar la aplicación JavaFX -->
    <action>
        <actionName>CUSTOM-runBiblioteca</actionName>
        <displayName>Run Biblioteca</displayName>
        <goals>
            <goal>clean</goal>
            <goal>javafx:run</goal>
        </goals>
        <activatedProfiles>
            <activatedProfile>biblioteca</activatedProfile>
        </activatedProfiles>
    </action>

    <!-- Acción para ejecutar la aplicación con el exec-maven-plugin -->
    <action>
        <actionName>runWithExec</actionName>
        <displayName>Run with Exec Plugin</displayName>
        <goals>
            <goal>process-classes</goal>
            <goal>org.codehaus.mojo:exec-maven-plugin:3.1.0:exec</goal>
        </goals>
        <properties>
            <exec.vmArgs></exec.vmArgs>
            <exec.args>${exec.vmArgs} -classpath %classpath ${exec.mainClass} ${exec.appArgs}</exec.args>
            <exec.appArgs></exec.appArgs>
            <exec.mainClass>com.tecno.biblioteca.App</exec.mainClass>
            <exec.executable>java</exec.executable>
        </properties>
    </action>

    <!-- Acción personalizada para compilar y ejecutar la aplicación JavaFX -->
    <action>
        <actionName>CUSTOM-buildAndRunBiblioteca</actionName>
        <displayName>Build and Run Biblioteca</displayName>
        <goals>
            <goal>clean</goal>
            <goal>compile</goal>
            <goal>javafx:run</goal>
        </goals>
        <activatedProfiles>
            <activatedProfile>biblioteca</activatedProfile>
        </activatedProfiles>
    </action>

    <!-- Acción para compilar el proyecto sin ejecutarlo -->
    <action>
        <actionName>compileOnly</actionName>
        <displayName>Compile Only</displayName>
        <goals>
            <goal>clean</goal>
            <goal>compile</goal>
        </goals>
    </action>

    <!-- Acción para depurar el proyecto JavaFX -->
    <action>
        <actionName>debugBiblioteca</actionName>
        <displayName>Debug Biblioteca</displayName>
        <goals>
            <goal>clean</goal> <!-- Limpia el proyecto -->
            <goal>javafx:run</goal> <!-- Ejecuta la aplicación JavaFX -->
        </goals>
        <properties>
            <exec.vmArgs>-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=5005</exec.vmArgs> <!-- Habilita la depuración remota -->
        </properties>
        <activatedProfiles>
            <activatedProfile>biblioteca</activatedProfile> <!-- Activa el perfil de biblioteca -->
        </activatedProfiles>
    </action>
</actions>

